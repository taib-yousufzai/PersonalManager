rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Deny everything by default — explicit allow rules below.
    match /{document=**} {
      allow read, write: if false;
    }

    // All user data lives under users/{uid}/.
    // Only the authenticated owner may access their own data.
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Income: enforce positive amount on create/update.
    match /users/{uid}/income/{id} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create, update: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.amount is number
        && request.resource.data.amount > 0;
      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    // Expenses: enforce positive amount on create/update.
    match /users/{uid}/expenses/{id} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create, update: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.amount is number
        && request.resource.data.amount > 0;
      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    // Savings goals: enforce valid type on create/update.
    match /users/{uid}/savingsGoals/{id} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create, update: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.type in ['fixed', 'percentage'];
      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    // Categories, budgets, and monthly reports: owner-only access.
    match /users/{uid}/categories/{id} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    match /users/{uid}/budgets/{id} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    match /users/{uid}/monthlyReports/{id} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Scheduled payments: owner-only, amount must be positive.
    match /users/{uid}/scheduledPayments/{id} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create, update: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.amount is number
        && request.resource.data.amount > 0;
      allow delete: if request.auth != null && request.auth.uid == uid;
    }
  }
}
